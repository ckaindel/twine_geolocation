:: Karte {"position":"550,225","size":"100,100"}
<div id="map" style="height: 400px;"></div> <<set $debug to false>>
//Debug-Position: 48.198799,16.355411 / 48.198988,16.356344 / 48.198581,16.357218 / 48.198806,16.358187

<<script>>
/* Annahmen:
   - $stage wählt das aktuelle Ziel aus $markers
   - $markers[$stage] hat { coords: [lat,lng], passage: "QuizPassage" }
   - <div id="map"></div> existiert in der Passage (mit Höhe via CSS)
*/
const m = State.variables.markers[State.variables.stage];
const debugMode = (typeof State.variables.debug !== 'undefined') ? State.variables.debug : true;

setup.loadLeaflet()
  .then(function () {
    // Map + Marker aufsetzen
    setup.leaflet.initScene({
      containerId: "map",
      center: m.coords,
      zoom: 17,
      targetCoords: m.coords,
      targetInteractive: debugMode,
      quizPassage: m.passage,
      userStart: State.variables.usermarker || [0, 0],
      userIconUrl: 'https://upload.wikimedia.org/wikipedia/commons/thumb/3/30/Man_walking_icon_1410105361.svg/250px-Man_walking_icon_1410105361.svg.png'
    });

    // Debug oder Geolocation starten
    if (debugMode) {
      setup.leaflet.startDebugUI({ containerSelector: "#map", intervalMs: 2000 });
    } else {
      setup.leaflet.startGeolocation({
        enableHighAccuracy: true,
        maximumAge: 1000,
        timeout: 5000
      });
    }
  })
  .catch(console.error);
<</script>>


:: Karte mit Autopan {"position":"225,350","size":"100,100"}
<div id="map" style="height: 400px;"></div> <<set $debug to false>>
//Debug-Position: 48.198799,16.355411 / 48.198988,16.356344 / 48.198581,16.357218 / 48.198806,16.358187

<<script>>
const m = State.variables.markers[State.variables.stage];
const debugMode = (typeof State.variables.debug !== 'undefined') ? State.variables.debug : true;

setup.loadLeaflet()
  .then(function () {
    // Szene sauber initialisieren (macht intern Teardown)
    setup.leaflet.initScene({
      containerId: "map",
      center: m.coords,
      zoom: 17,
      targetCoords: m.coords,
      targetInteractive: debugMode,
      quizPassage: m.passage,
      userStart: State.variables.usermarker || [0, 0],
      userIconUrl: 'https://upload.wikimedia.org/wikipedia/commons/thumb/3/30/Man_walking_icon_1410105361.svg/250px-Man_walking_icon_1410105361.svg.png'
    });

    if (debugMode) {
      // --- DEBUG: ohne AutoPan ---
      setup.leaflet.startDebugUI({ containerSelector: "#map", intervalMs: 2000 });

      // Falls zuvor ein Geolocation-Watch lief (von einem früheren Besuch), sicherheitshalber stoppen
      if (setup.leafletGeoWatchId && navigator.geolocation) {
        navigator.geolocation.clearWatch(setup.leafletGeoWatchId);
        setup.leafletGeoWatchId = null;
      }

    } else {
      // --- GEOLOCATION: mit AutoPan ---
      // 1) Vorherigen Watch (falls vorhanden) stoppen, damit nichts doppelt läuft
      if (setup.leafletGeoWatchId && navigator.geolocation) {
        navigator.geolocation.clearWatch(setup.leafletGeoWatchId);
        setup.leafletGeoWatchId = null;
      }

      // 2) Neuen Watch starten und die Modulfunktion mit autoPan nutzen
      if (navigator.geolocation) {
        setup.leafletGeoWatchId = navigator.geolocation.watchPosition(function (pos) {
          setup.leaflet.updateUserPosition(
            pos.coords.latitude,
            pos.coords.longitude,
            { autoPan: true }           // <— Karte folgt der Position
          );
        }, function (err) {
          console.error("Geolocation-Fehler:", err);
        }, {
          enableHighAccuracy: true,
          maximumAge: 1000,
          timeout: 5000
        });
      } else {
        console.warn("Geolocation wird nicht unterstützt.");
      }
    }
  })
  .catch(console.error);
<</script>>


