:: StoryScript [script]
//UIBar.destroy();

/* =========================
   Leaflet Utilities für SugarCube
   ========================= */

setup.loadLeaflet = function () {
  return new Promise(function (resolve, reject) {
    // CSS laden (nur einmal)
    if (!$("link[href*='leaflet.css']").length) {
      $("head").append('<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />');
    }
    // JS laden (nur einmal)
    if (typeof L === "undefined") {
      $.getScript("https://unpkg.com/leaflet@1.9.4/dist/leaflet.js")
        .done(resolve)
        .fail(function () { reject("Leaflet konnte nicht geladen werden."); });
    } else {
      resolve();
    }
  });
};

/* =========================
   setup.leaflet: Map-Controller
   ========================= */
setup.leaflet = (function () {

  // interner Kontext (Handles, Status)
  const ctx = {
    map: null,
    userMarker: null,
    targetMarker: null,
    debugTimer: null,
    geoWatchId: null,
    uiIds: null,
    popupShown: false,
    targetCoords: null,
  };

  // ------ Helfer
  function teardown() {
    try {
      if (ctx.debugTimer) { clearInterval(ctx.debugTimer); ctx.debugTimer = null; }
      if (ctx.geoWatchId && navigator.geolocation) {
        navigator.geolocation.clearWatch(ctx.geoWatchId);
        ctx.geoWatchId = null;
      }
      if (ctx.map) { ctx.map.remove(); ctx.map = null; }
      if (ctx.uiIds && ctx.uiIds.wrapper) { $(`#${ctx.uiIds.wrapper}`).remove(); }
      ctx.userMarker = null;
      ctx.targetMarker = null;
      ctx.uiIds = null;
      ctx.popupShown = false;
      ctx.targetCoords = null;
    } catch (e) {
      console.warn("Teardown-Warnung:", e);
    }
  }

  function buildIds() {
    const uid = Date.now();
    return {
      wrapper: `dbgWrap-${uid}`,
      lat:     `dbgLat-${uid}`,
      lng:     `dbgLng-${uid}`,
      btn:     `dbgBtn-${uid}`,
    };
  }

  function createMap(containerId, center, zoom = 17, tileUrl, attribution) {
    const map = L.map(containerId).setView(center, zoom);
    L.tileLayer(tileUrl || 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: attribution || '&copy; OpenStreetMap contributors'
    }).addTo(map);
    ctx.map = map;
    return map;
  }

  function ensureUserMarker(initialCoords, iconUrl) {
    const userIcon = L.icon({
      iconUrl: iconUrl || 'https://upload.wikimedia.org/wikipedia/commons/thumb/3/30/Man_walking_icon_1410105361.svg/250px-Man_walking_icon_1410105361.svg.png',
      iconSize: [20, 32],
      iconAnchor: [10, 32]
    });

    if (!Array.isArray(initialCoords) || initialCoords.length !== 2) {
      initialCoords = [0, 0];
    }

    if (!State.variables.usermarker || State.variables.usermarker.length !== 2) {
      State.variables.usermarker = initialCoords.slice();
    }

    ctx.userMarker = L.marker(State.variables.usermarker, { icon: userIcon }).addTo(ctx.map);
    return ctx.userMarker;
  }

  function addTargetMarker(coords, { interactive = false } = {}) {
    ctx.targetCoords = coords;
    ctx.targetMarker = L.marker(coords, { interactive }).addTo(ctx.map);
    return ctx.targetMarker;
  }

  function bindQuizPopup(passageName, selector = ".gotoPassage") {
    if (!ctx.targetMarker) return;
    ctx.targetMarker.bindPopup('<a href="#" class="gotoPassage">Quiz öffnen</a>');
    ctx.map.on('popupopen', function (e) {
      const $link = $(e.popup._contentNode).find(selector);
      $link.on("click", function (ev) {
        ev.preventDefault();
        Engine.play(passageName);
      });
    });
  }

  function distanceToTarget(fromCoords) {
    if (!ctx.map || !ctx.targetCoords) return Infinity;
    return ctx.map.distance(fromCoords, ctx.targetCoords);
  }

  function updateUserPosition(lat, lng, { autoPan = false } = {}) {
    if (!ctx.userMarker || !ctx.map) return;
    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;

    const pos = [lat, lng];
    State.variables.usermarker = pos;
    ctx.userMarker.setLatLng(pos);

    if (autoPan) {
      ctx.map.panTo(pos, { animate: true, duration: 0.4 });
    }

    const dist = distanceToTarget(pos);
    // Schwelle 30 m: Popup toggeln
    if (dist <= 30 && !ctx.popupShown) {
      if (ctx.targetMarker) ctx.targetMarker.openPopup();
      ctx.popupShown = true;
    } else if (dist > 30 && ctx.popupShown) {
      ctx.map.closePopup();
      ctx.popupShown = false;
    }

    return dist;
  }

  function startDebugUI({ containerSelector = "#map", intervalMs = 2000 } = {}) {
    // UI-IDs erzeugen + Wrapper im DOM platzieren
    ctx.uiIds = buildIds();
    const $host = $(containerSelector).length ? $(containerSelector).parent() : $("body");

    const form = $(`
      <div id="${ctx.uiIds.wrapper}" style="position:absolute; top:10px; left:10px; background:white; padding:10px; z-index:1000; box-shadow:0 2px 6px rgba(0,0,0,0.2); border-radius:6px;">
        <div style="font-weight:600; margin-bottom:6px;">Debug-Position</div>
        <label style="display:block; margin-bottom:4px;">Lat:
          <input type="text" id="${ctx.uiIds.lat}" value="${State.variables.usermarker ? State.variables.usermarker[0] : 0}" style="width:140px;">
        </label>
        <label style="display:block; margin-bottom:8px;">Lng:
          <input type="text" id="${ctx.uiIds.lng}" value="${State.variables.usermarker ? State.variables.usermarker[1] : 0}" style="width:140px;">
        </label>
        <button id="${ctx.uiIds.btn}">Position setzen</button>
      </div>
    `);
    $host.append(form);

    // Klick-Handler
    $(`#${ctx.uiIds.btn}`).on("click", function () {
      const lat = parseFloat($(`#${ctx.uiIds.lat}`).val());
      const lng = parseFloat($(`#${ctx.uiIds.lng}`).val());
      updateUserPosition(lat, lng);
    });

    // Periodisches Update
    ctx.debugTimer = setInterval(function () {
      const lat = parseFloat($(`#${ctx.uiIds.lat}`).val());
      const lng = parseFloat($(`#${ctx.uiIds.lng}`).val());
      updateUserPosition(lat, lng);
    }, intervalMs);

    // einmal initial auslösen
    const lat0 = parseFloat($(`#${ctx.uiIds.lat}`).val());
    const lng0 = parseFloat($(`#${ctx.uiIds.lng}`).val());
    updateUserPosition(lat0, lng0);
  }

  function stopDebugUI() {
    if (ctx.debugTimer) { clearInterval(ctx.debugTimer); ctx.debugTimer = null; }
    if (ctx.uiIds && ctx.uiIds.wrapper) { $(`#${ctx.uiIds.wrapper}`).remove(); }
    ctx.uiIds = null;
  }

  function startGeolocation(options) {
    if (!navigator.geolocation) {
      console.warn("Geolocation wird nicht unterstützt.");
      return null;
    }
    const opts = Object.assign({
      enableHighAccuracy: true,
      maximumAge: 1000,
      timeout: 5000
    }, options || {});
    ctx.geoWatchId = navigator.geolocation.watchPosition(function (pos) {
      updateUserPosition(pos.coords.latitude, pos.coords.longitude);
    }, function (err) {
      console.error("Geolocation-Fehler:", err);
    }, opts);
    return ctx.geoWatchId;
  }

  function stopGeolocation() {
    if (ctx.geoWatchId && navigator.geolocation) {
      navigator.geolocation.clearWatch(ctx.geoWatchId);
      ctx.geoWatchId = null;
    }
  }

  // Öffentliche API
  return {
    // Lebenszyklus
    teardown,
    // Initialisierung
    createMap,
    ensureUserMarker,
    addTargetMarker,
    bindQuizPopup,
    // Bewegungen & Abstand
    updateUserPosition,
    distanceToTarget,
    // Debug & Geo
    startDebugUI,
    stopDebugUI,
    startGeolocation,
    stopGeolocation,
    // bequeme Kombi-Init
    initScene: function ({
      containerId = "map",
      center = [0, 0],
      zoom = 17,
      targetCoords = null,
      targetInteractive = false,
      quizPassage = null,
      userStart = [0, 0],
      userIconUrl,
      tileUrl,
      attribution
    } = {}) {
      teardown();
      const map = createMap(containerId, center, zoom, tileUrl, attribution);
      if (targetCoords) {
        addTargetMarker(targetCoords, { interactive: targetInteractive });
      }
      if (quizPassage) {
        bindQuizPopup(quizPassage);
      }
      ensureUserMarker(userStart, userIconUrl);
      return map;
    }
  };
})();



